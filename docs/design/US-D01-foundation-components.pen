{
  "version": "2.14",
  "children": [
    {
      "type": "frame",
      "id": "page",
      "x": 0,
      "y": 0,
      "name": "US-D01 Foundation & Components",
      "width": 1440,
      "fill": "$color.bg",
      "layout": "vertical",
      "gap": 48,
      "padding": 48,
      "children": [
        {
          "type": "text",
          "id": "page-title",
          "name": "Page Title",
          "fill": "$color.text",

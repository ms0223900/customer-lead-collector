          "lineHeight": 1.5,
          "fontFamily": "Fira Sans",
          "fontSize": 36,
          "fontWeight": "700"
        },
        {
          "type": "text",
          "id": "page-subtitle",
          "name": "Page Subtitle",
          "fill": "$color.text-secondary",
          "content": "Lead Collector MVP · 《聊著聊著，AI 就做完了》",
          "lineHeight": 1.5,
          "fontFamily": "Fira Sans",
          "fontSize": 16,
          "fontWeight": "normal"
        },
        {
          "type": "frame",
          "id": "sec-colors",
          "name": "Section / Colors",
          "width": "fill_container",
